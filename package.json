{
  "name": "iseyaa-tiarionx-monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=iseyaa-web-core",
    "dev:ai-engine": "turbo run dev --filter=iseyaa-ai-engine",
    "env:pull": "vercel env pull .env.local",
    "db:sync": "python sync_supabase_v4.py",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@8.15.4"
}
